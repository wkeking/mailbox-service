# Local development template. Safe to use HTTP and looser defaults.

APP_ENV=development
AUTO_MIGRATE_ON_STARTUP=true
TLS_MODE=disabled
DEBUG_TOKEN_LOGGING=false

DATABASE_URL=mysql+pymysql://mailbox_service:mailbox_service@127.0.0.1:3306/mailbox_service
ADMIN_API_TOKEN=dev-admin-token-change-me-please
CREDENTIAL_ENCRYPTION_KEY=
# Generate: python -c "import base64,os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"

CORS_ALLOW_ORIGINS=http://localhost:5173
FORWARDED_ALLOW_IPS=127.0.0.1
TRUSTED_HOSTS=localhost,127.0.0.1

PROXY_ENABLED=true
PROXY_REQUIRED=false
