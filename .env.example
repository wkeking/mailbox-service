# =============================================================================
# Mailbox Service 环境变量示例
# 复制为本目录 .env 后按实际环境修改；切勿将含真实密钥的 .env 提交到版本库。
# =============================================================================

# -----------------------------------------------------------------------------
# 数据库
# -----------------------------------------------------------------------------
# MySQL 8 连接串（SQLAlchemy + PyMySQL）。
# 共享基础设施：Docker/infra（容器 mysql-host，网络 external_network，root/change-me）。
# - 本机 uvicorn：主机用 127.0.0.1（端口 3306）
# - Docker Compose：主机必须用 mysql-host，勿写 127.0.0.1
# 示例（Compose）：DATABASE_URL=mysql+pymysql://root:change-me@mysql-host:3306/mailbox_service
DATABASE_URL=mysql+pymysql://root:change-me@127.0.0.1:3306/mailbox_service

# 启动时自动检测并执行尚未应用的 migrations/*.sql（版本记录在 schema_migrations 表）。
# true=自动迁移；false=关闭，改由运维手动执行 SQL。
AUTO_MIGRATE_ON_STARTUP=true

# 可选：自定义迁移目录的绝对/相对路径。
# 留空则依次尝试：当前工作目录/migrations、镜像或项目内 /app/migrations。
# MIGRATIONS_DIR=/app/migrations

# -----------------------------------------------------------------------------
# 管理与加密
# -----------------------------------------------------------------------------
# 管理员 API Token。请求管理接口时写入 Header：X-Admin-Token。
# 生产环境长度须大于 10 位（勿使用 admin/root/change-me 等占位值）。
ADMIN_API_TOKEN=replace-with-a-long-random-admin-token

# 凭证加密密钥：URL-safe Base64，解码后必须恰好 32 字节（AES-GCM）。
# 用于加密保存邮箱密码、Refresh Token、代理账号密码等。
# 生成示例：python -c "import base64,os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
CREDENTIAL_ENCRYPTION_KEY=replace-with-aes-gcm-key

# -----------------------------------------------------------------------------
# 运行环境与诊断
# -----------------------------------------------------------------------------
# 运行环境：development | test | production
APP_ENV=development

# Token 诊断日志开关。仅当 APP_ENV=development 且本项为 true 时输出诊断信息。
# 日志中为掩码与指纹，不会输出完整 Token 明文。
DEBUG_TOKEN_LOGGING=false

# -----------------------------------------------------------------------------
# CORS（浏览器管理台跨域）
# -----------------------------------------------------------------------------
# 允许的浏览器 Origin，多个用英文逗号分隔。
# 本地 Vite 开发：http://localhost:5173
# Docker 同源管理台可设为 *
CORS_ALLOW_ORIGINS=http://localhost:5173

# -----------------------------------------------------------------------------
# 出口代理池
# -----------------------------------------------------------------------------
# 是否启用出口代理能力（总开关）。
PROXY_ENABLED=true

# 是否强制走代理。true 时无健康代理会拒绝直连，返回 NO_HEALTHY_EGRESS_PROXY。
PROXY_REQUIRED=true

# 经代理建立连接的超时时间（秒）。
PROXY_CONNECT_TIMEOUT_SECONDS=10

# 经代理读取响应的超时时间（秒）。
PROXY_READ_TIMEOUT_SECONDS=30

# 连续失败多少次后将代理置为冷却。
PROXY_FAILURE_THRESHOLD=3

# 代理冷却时长（秒）。
PROXY_COOLDOWN_SECONDS=300

# 同一邮箱两次切换代理之间的最小间隔（秒）。
PROXY_SWITCH_MINIMUM_INTERVAL_SECONDS=60

# 后台健康探测任务的执行间隔（秒）。
PROXY_HEALTH_CHECK_INTERVAL_SECONDS=300

# -----------------------------------------------------------------------------
# SMSBower Gmail（Phase 1A inventory；默认关闭）
# -----------------------------------------------------------------------------
# true 时启用补货与显式 provider=smsbower_gmail 领取。
SMSBOWER_ENABLED=false
SMSBOWER_API_BASE=https://smsbower.page/api/mail
# 切勿写入仓库或 provider_config_json；仅 env / secret file。
SMSBOWER_API_KEY=
SMSBOWER_SERVICE=openai
SMSBOWER_DOMAIN=gmail.com
# 可选最高价格；空表示不限制。
SMSBOWER_MAX_PRICE=
SMSBOWER_INSTANCE_ID=default
SMSBOWER_REQUEST_TIMEOUT_SECONDS=30

# -----------------------------------------------------------------------------
# Microsoft OAuth / IMAP
# -----------------------------------------------------------------------------
# Microsoft 身份平台 Token 端点（刷新 Access Token / Refresh Token）。
MICROSOFT_TOKEN_ENDPOINT=https://login.microsoftonline.com/common/oauth2/v2.0/token

# Outlook IMAP 主机与端口（XOAUTH2）。
MICROSOFT_IMAP_HOST=outlook.office365.com
MICROSOFT_IMAP_PORT=993

# 读取缓存 Access Token 时的提前刷新余量（秒）。
# 例如 120 表示在过期前 120 秒视为需要刷新。
ACCESS_TOKEN_REFRESH_SKEW_SECONDS=120

# -----------------------------------------------------------------------------
# Refresh Token 保活
# -----------------------------------------------------------------------------
# 是否开启进程内 RT 保活定时任务（到期前主动刷新，避免长期闲置失效）。
REFRESH_TOKEN_KEEPALIVE_ENABLED=true

# 保活任务扫描间隔（秒）。默认 86400=1 天。
REFRESH_TOKEN_KEEPALIVE_INTERVAL_SECONDS=86400

# 按策略估算的 RT 寿命（天）。Microsoft 非 SPA 场景常见约 90 天。
REFRESH_TOKEN_LIFETIME_DAYS=90

# 在估算到期前多少天开始触发强制刷新。
REFRESH_TOKEN_KEEPALIVE_LEAD_DAYS=7

# 每次扫描最多处理的邮箱数量。
REFRESH_TOKEN_KEEPALIVE_BATCH_SIZE=20
