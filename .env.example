# MySQL 8 connection string. Do not use this development placeholder in production.
# Docker Compose 内网访问请用主机名 mysql，例如：
# DATABASE_URL=mysql+pymysql://mailbox_service:change-me@mysql:3306/mailbox_service
DATABASE_URL=mysql+pymysql://mailbox_service:change-me@127.0.0.1:3306/mailbox_service

# Set a high-entropy value and pass it in X-Admin-Token for the initial Admin API.
ADMIN_API_TOKEN=replace-with-a-long-random-admin-token

# URL-safe Base64 encoding of exactly 32 random bytes. Required for authenticated proxies.
CREDENTIAL_ENCRYPTION_KEY=replace-with-aes-gcm-key

# Token diagnostics are emitted only when both settings below are enabled.
# Logs contain masked values and SHA-256 fingerprints, never complete Tokens.
APP_ENV=development
DEBUG_TOKEN_LOGGING=false

# Browser origins allowed by CORS (comma-separated). Use * for same-host Docker admin UI.
# Local Vite dev: http://localhost:5173
CORS_ALLOW_ORIGINS=http://localhost:5173

# Enabling PROXY_REQUIRED prevents OAuth and IMAP from silently falling back to direct egress.
PROXY_ENABLED=true
PROXY_REQUIRED=true
PROXY_CONNECT_TIMEOUT_SECONDS=10
PROXY_READ_TIMEOUT_SECONDS=30
PROXY_FAILURE_THRESHOLD=3
PROXY_COOLDOWN_SECONDS=300
PROXY_SWITCH_MINIMUM_INTERVAL_SECONDS=60
PROXY_HEALTH_CHECK_INTERVAL_SECONDS=300

MICROSOFT_TOKEN_ENDPOINT=https://login.microsoftonline.com/common/oauth2/v2.0/token
MICROSOFT_IMAP_HOST=outlook.office365.com
MICROSOFT_IMAP_PORT=993
ACCESS_TOKEN_REFRESH_SKEW_SECONDS=120

# Refresh Token keepalive (Microsoft default non-SPA RT lifetime is about 90 days).
# The job force-refreshes due mailboxes so RT can slide / rotate before expiry.
REFRESH_TOKEN_KEEPALIVE_ENABLED=true
REFRESH_TOKEN_KEEPALIVE_INTERVAL_SECONDS=86400
REFRESH_TOKEN_LIFETIME_DAYS=90
REFRESH_TOKEN_KEEPALIVE_LEAD_DAYS=7
REFRESH_TOKEN_KEEPALIVE_BATCH_SIZE=20
