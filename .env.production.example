# Production environment template. Copy to .env and fill real secrets.
#
# Historical deployments may use root DB accounts, CORS_ALLOW_ORIGINS=*, and
# TLS_MODE=disabled. Prefer least-privilege DB users and explicit CORS when feasible.
# Still required: a long ADMIN_API_TOKEN and a real CREDENTIAL_ENCRYPTION_KEY.
# Still forbidden: FORWARDED_ALLOW_IPS=*

APP_ENV=production
AUTO_MIGRATE_ON_STARTUP=true
# TLS may be terminated outside this process.
TLS_MODE=disabled
ENABLE_HSTS=false
HSTS_MAX_AGE_SECONDS=86400

# Prefer a dedicated least-privilege database user.
# Host must be reachable from the app container/process (service name or IP).
DATABASE_URL=mysql+pymysql://mailbox:change-me@mysql-host:3306/mailbox_service

# Admin and encryption secrets (use Docker secrets / *_FILE when possible).
ADMIN_API_TOKEN=replace-with-admin-token-longer-than-10
# ADMIN_API_TOKEN_FILE=/run/secrets/admin_api_token
CREDENTIAL_ENCRYPTION_KEY=replace-with-urlsafe-base64-32-byte-key
# CREDENTIAL_ENCRYPTION_KEY_FILE=/run/secrets/credential_encryption_key

# Header-auth admin UI may use * for same-host or multi-origin setups.
CORS_ALLOW_ORIGINS=*
TRUSTED_HOSTS=localhost,127.0.0.1
# Trusted reverse-proxy addresses only — never *.
FORWARDED_ALLOW_IPS=127.0.0.1

BATCH_MAX_WORKERS=8
DATABASE_POOL_SIZE=16
DATABASE_MAX_OVERFLOW=8
DATABASE_POOL_TIMEOUT_SECONDS=5
DATABASE_POOL_RECYCLE_SECONDS=1800
MAIL_POLL_MAX_CONCURRENCY=32
MAIL_POLL_MAX_CONCURRENCY_PER_CLIENT=4
MAIL_POLL_MAX_CONCURRENCY_PER_LEASE=1
